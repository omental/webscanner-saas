APP_NAME=Web Scanner Service
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://YOUR_LOCAL_USERNAME@localhost:5432/webscanner
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SCANNER_MAX_DEPTH=2
SCANNER_MAX_PAGES=25
SCANNER_TIMEOUT_SECONDS=10
SCANNER_USER_AGENT=WebScannerBot/0.1
ENABLE_WAF_DETECTION=true
WAF_DETECTION_SAFE_PROBES=true
WAF_DETECTION_TIMEOUT_SECONDS=8
ENABLE_SUBDOMAIN_DISCOVERY=false
SUBDOMAIN_DISCOVERY_MAX_RESULTS=100
ENABLE_STORED_XSS_CHECKS=false
ENABLE_STORED_XSS_BROWSER_VERIFY=false
STORED_XSS_MAX_FORMS=3
STORED_XSS_REVISIT_MAX_PAGES=10
ENABLE_ADVANCED_SQLI_CHECKS=false
ADVANCED_SQLI_MAX_PARAMS=10
ADVANCED_SQLI_MAX_PROBES_PER_PARAM=4
ADVANCED_SQLI_TIMEOUT_SECONDS=8
ENABLE_SSRF_CHECKS=false
SSRF_CALLBACK_URL=
SSRF_MAX_PARAMS=10
SSRF_TIMEOUT_SECONDS=8
ENABLE_RCE_CHECKS=false
RCE_MAX_PARAMS=10
RCE_TIMEOUT_SECONDS=8
NVD_IMPORT_PATH=/absolute/path/to/nvd.json
MITRE_IMPORT_PATH=/absolute/path/to/mitre-cve.json
KEV_IMPORT_PATH=/absolute/path/to/kev.csv
GHSA_IMPORT_PATH=/absolute/path/to/github-advisories.json
OSV_IMPORT_PATH=/absolute/path/to/osv.json
EXPLOITDB_IMPORT_PATH=/absolute/path/to/exploitdb.csv
WORDFENCE_IMPORT_PATH=/absolute/path/to/wordfence.json

# --- OpenRouter / LLM ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=minimax/minimax-m2.5:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
APP_PUBLIC_URL=http://localhost:3000
APP_NAME=Web Vulnerability Scanner
